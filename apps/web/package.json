{
  "name": "islegalcannabis",
  "version": "0.1.0",
  "private": true,
  "browserslist": {
    "production": [
      "baseline widely available"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "scripts": {
    "dev": "bash ../../tools/ui/ui_dev_ssot.sh",
    "web:dev": "next dev -p 3000 -H 127.0.0.1",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "status:engine:audit": "npm exec -- tsx scripts/status-engine-audit-v3.ts",
    "popup:profile:audit": "npm exec -- tsx scripts/popup-profile-audit.ts",
    "popup:seo:audit": "npm exec -- tsx scripts/popup-seo-content-audit.ts",
    "popup:visual:audit": "npm exec -- tsx scripts/popup-visual-audit.ts",
    "popup:visual:audit:full": "npm exec -- tsx scripts/popup-visual-audit-full.ts",
    "geo:sync:audit": "npm exec -- tsx scripts/geo-sync-audit.ts",
    "ui:e2e": "npx -y playwright test e2e/favicon.spec.ts e2e/map-render.spec.ts e2e/new-map.geo-perf.spec.ts e2e/new-map.geo.spec.ts e2e/new-map.popup.spec.ts e2e/new-map.preload.spec.ts e2e/mobile-cold-start.spec.ts e2e/us-state-route.spec.ts",
    "pw:ui": "npx -y playwright test --ui",
    "pw:headed": "npx -y playwright test --headed",
    "pw:state": "npx -y playwright test e2e/us-state-route.spec.ts --headed --project=webkit",
    "version:show": "cat ../../VERSION",
    "validate:laws": "node ../../tools/validate-laws.js"
  },
  "dependencies": {
    "@islegal/shared": "file:../../packages/shared",
    "@vercel/analytics": "^2.0.1",
    "maplibre-gl": "^5.21.1",
    "next": "16.0.10",
    "react": "19.2.1",
    "react-dom": "19.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.0.10",
    "typescript": "^5",
    "vitest": "^2.1.4"
  }
}

{
  "name": "islegalcannabis",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bash ../../tools/ui/ui_dev_ssot.sh",
    "web:dev": "next dev -p 3000 -H 127.0.0.1",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "ui:e2e": "npx -y playwright test e2e/favicon.spec.ts e2e/map-render.spec.ts e2e/new-map.geo-perf.spec.ts e2e/new-map.geo.spec.ts e2e/new-map.popup.spec.ts e2e/new-map.preload.spec.ts e2e/us-state-route.spec.ts",
    "pw:ui": "npx -y playwright test --ui",
    "pw:headed": "npx -y playwright test --headed",
    "pw:state": "npx -y playwright test e2e/us-state-route.spec.ts --headed --project=webkit",
    "version:show": "cat ../../VERSION",
    "validate:laws": "node ../../tools/validate-laws.js"
  },
  "dependencies": {
    "@islegal/shared": "file:../../packages/shared",
    "@types/leaflet": "^1.9.21",
    "@vercel/analytics": "^2.0.1",
    "leaflet": "^1.9.4",
    "maplibre-gl": "^5.21.1",
    "next": "16.0.10",
    "react": "19.2.1",
    "react-dom": "19.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.0.10",
    "typescript": "^5",
    "vitest": "^2.1.4"
  }
}
